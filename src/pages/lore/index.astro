---
import SectionPageLayout from "../../layouts/SectionPageLayout.astro";
import { collectionEntryUrl, getLoreEntries } from "../../lib/content";

const items = await getLoreEntries();
---

<SectionPageLayout title="世界观" description="汐塔世界观专题文章索引。" heading="世界观">
  <div class="wiki-list">
    {items.length === 0 ? (
      <div class="empty-note">这里还没有世界观专题。</div>
    ) : (
      items.map((item) => (
        <a class="wiki-item" href={collectionEntryUrl("lore", item.slug)}>
          <h3 class="wiki-title">{item.data.title}</h3>
          {item.data.summary ? <p class="wiki-desc">{item.data.summary}</p> : <p class="wiki-desc">点击进入阅读。</p>}
        </a>
      ))
    )}
  </div>
</SectionPageLayout>
