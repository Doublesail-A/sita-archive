---
import { getCollection } from "astro:content";
import ArticlePageLayout from "../../layouts/ArticlePageLayout.astro";
import { formatDate } from "../../lib/format";

export async function getStaticPaths() {
  const entries = await getCollection("wiki");
  return entries.map((entry) => ({
    params: { slug: entry.slug },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await entry.render();
const modifiedTime = (entry.data.pubDate ?? entry.data.date)?.toISOString?.();
---

<ArticlePageLayout
  title={entry.data.title}
  description={entry.data.description}
  metaLabel="修改日期"
  metaValue={formatDate(entry.data.pubDate ?? entry.data.date)}
  backHref="/wiki/"
  backLabel="返回 wiki"
  leftLink={{ href: "/wiki/", label: "wiki" }}
  modifiedTime={modifiedTime}
  tags={entry.data.tags ?? []}
  cover={entry.data.cover}
  schemaType="Article"
>
  <Content />
</ArticlePageLayout>
