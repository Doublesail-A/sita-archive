---
import BaseLayout from "../layouts/BaseLayout.astro";
import HomeFooter from "../components/HomeFooter.astro";
import HomeCollectionSection from "../components/HomeCollectionSection.astro";
import { getImportantHomeCards, getMovieEntries } from "../lib/content";
import { HOME_DESKTOP_LINKS, SITE_DESCRIPTION, SITE_TITLE } from "../lib/site";
import { toAssetSrc } from "../lib/format";

import logoInline from "../img/logo/logo.svg?raw";

const desktopImgs = Object.values(import.meta.glob("../img/main/desktop/*", { eager: true, import: "default" })) as unknown[];
const mobileImgs = Object.values(import.meta.glob("../img/main/mobile/*", { eager: true, import: "default" })) as unknown[];

const desktopBase = desktopImgs[0] ?? null;
const mobileBase = mobileImgs[0] ?? null;
const desktopSlides = desktopImgs.slice(0, 6);
const mobileSlides = mobileImgs.slice(0, 6);

const [newsItems, wikiItems, doujinItems, storiesItems, movies] = await Promise.all([
  getImportantHomeCards("news", 3),
  getImportantHomeCards("wiki", 3),
  getImportantHomeCards("doujin", 3),
  getImportantHomeCards("stories", 3),
  getMovieEntries(),
]);
---

<BaseLayout title={SITE_TITLE} description={SITE_DESCRIPTION}>
  <header class="hero" id="top">
    <div class="hero-nav">
      <div class="hero-nav__row">
        <div class="nav-left">
          <a class="outline-pill" href="/">CETUS</a>
        </div>

        <div class="nav-right">
          <div class="desktop-links">
            {HOME_DESKTOP_LINKS.map((link) => (
              <a class="nav-link" href={link.href}>{link.label}</a>
            ))}
          </div>

          <details class="menu" id="menu">
            <summary class="burger" aria-label="menu">☰</summary>
            <div class="menu-panel" aria-label="menu panel">
              {HOME_DESKTOP_LINKS.map((link) => (
                <a href={link.href}>{link.label}</a>
              ))}
            </div>
          </details>
        </div>
      </div>
    </div>

    <div class="hero-center">
      <div class="logo-wrap" set:html={logoInline} aria-label="汐塔 logo"></div>

      <div class="hero-actions">
        <a class="square-btn" href="/wiki/" data-activate>WIKI</a>
        <a class="square-btn" href="/doujin/" data-activate>DOUJIN</a>
      </div>
    </div>

    <div class="hero-media" aria-hidden="true">
      <picture>
        {mobileBase ? <source media="(max-width: 820px)" srcset={toAssetSrc(mobileBase)} /> : null}

        {desktopBase ? (
          <img id="heroBaseImg" src={toAssetSrc(desktopBase)} alt="" />
        ) : (
          <img
            id="heroBaseImg"
            alt=""
            src={`data:image/svg+xml,${encodeURIComponent(`<svg xmlns='http://www.w3.org/2000/svg' width='1600' height='900'><rect width='100%' height='100%' fill='#ece6da'/></svg>`)}`}
          />
        )}
      </picture>

      {desktopSlides.length > 1 ? (
        <div class="hero-slides" data-desktop-slides>
          {desktopSlides.map((img) => <img src={toAssetSrc(img)} alt="" />)}
        </div>
      ) : null}

      {mobileSlides.length > 1 ? (
        <div class="hero-slides" style="display:none" data-mobile-slides>
          {mobileSlides.map((img) => <img src={toAssetSrc(img)} alt="" />)}
        </div>
      ) : null}
    </div>
  </header>

  <main class="wrap">
    <HomeCollectionSection id="news" title="news" items={newsItems} href="/news/" emptyText="暂无 important news。" />

    <section class="section" id="movies">
      <div class="section-head section-head--home">
        <h2 class="h2">movies</h2>
      </div>

      <div class="movies-strip-wrap">
        <button class="movies-strip-nav" type="button" data-movies-prev aria-label="向左滑动视频列表">
          <svg width="18" height="18" viewBox="0 0 24 24" aria-hidden="true">
            <path d="M15.5 4.5L8 12l7.5 7.5" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </button>

        <div class="movies-strip" data-movies-strip>
          {movies.length === 0 ? (
            <div class="movies-strip__empty">这里还没有 movies 条目。</div>
          ) : (
            movies.map((movie) => (
              <a class="movie-card" href={movie.link} target="_blank" rel="noreferrer">
                <div class="movie-card__cover-shell">
                  <img class="movie-card__cover" src={movie.cover} alt={movie.title} loading="lazy" />
                </div>
                <div class="movie-card__meta">{movie.date ? movie.date.toISOString().slice(0, 10) : "—"}</div>
                <div class="movie-card__title">{movie.title}</div>
              </a>
            ))
          )}
        </div>

        <button class="movies-strip-nav" type="button" data-movies-next aria-label="向右滑动视频列表">
          <svg width="18" height="18" viewBox="0 0 24 24" aria-hidden="true">
            <path d="M8.5 4.5L16 12l-7.5 7.5" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </button>
      </div>
    </section>

    <HomeCollectionSection id="wiki" title="wiki" items={wikiItems} href="/wiki/" emptyText="暂无 important wiki。" />
    <HomeCollectionSection id="doujin" title="doujin" items={doujinItems} href="/doujin/" emptyText="暂无 important doujin。" />
    <HomeCollectionSection id="stories" title="stories" items={storiesItems} href="/stories/" emptyText="暂无 important stories。" />
  </main>

  <HomeFooter />
  <script src="/scripts/home.js" defer></script>
</BaseLayout>
