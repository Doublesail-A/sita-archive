---
import BaseLayout from "./BaseLayout.astro";
import PageTopbar from "../components/PageTopbar.astro";
import { DEFAULT_PAGE_LINKS, SITE_TITLE, buildBreadcrumbJsonLd, mergeKeywords, type SiteLink } from "../lib/site";

interface Props {
  title: string;
  description?: string;
  heading?: string;
  backHref?: string;
  backLabel?: string;
  leftLink?: SiteLink;
  rightLinks?: SiteLink[];
  keywords?: string[];
}

const {
  title,
  description,
  heading = title,
  backHref = "/",
  backLabel = "home",
  leftLink = { href: "/", label: "home" },
  rightLinks = DEFAULT_PAGE_LINKS,
  keywords = [],
} = Astro.props as Props;

const pathname = Astro.url.pathname;
const pageKeywords = mergeKeywords([title, heading, ...keywords]);
const jsonLd = [
  {
    "@context": "https://schema.org",
    "@type": "CollectionPage",
    name: `${heading} · ${SITE_TITLE}`,
    description,
    url: new URL(pathname, Astro.site).toString(),
    inLanguage: "zh-CN",
    keywords: pageKeywords.join(", "),
  },
  buildBreadcrumbJsonLd([
    { name: "首页", path: "/" },
    { name: heading, path: pathname },
  ]),
];
---

<BaseLayout title={`${title} · ${SITE_TITLE}`} description={description} keywords={pageKeywords} jsonLd={jsonLd}>
  <main class="wrap" style="padding-top:22px;padding-bottom:64px;">
    <PageTopbar leftLink={leftLink} rightLinks={rightLinks} />

    <section class="section" style="padding-top:24px;">
      <div class="section-head">
        <h2 class="h2">{heading}</h2>
        <a class="more" href={backHref}>{backLabel}</a>
      </div>

      <slot />
    </section>
  </main>
</BaseLayout>
