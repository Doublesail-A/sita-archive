---
import BaseLayout from "./BaseLayout.astro";
import PageTopbar from "../components/PageTopbar.astro";
import { DEFAULT_PAGE_LINKS, SITE_TITLE, type SiteLink } from "../lib/site";

interface Props {
  title: string;
  description?: string;
  heading?: string;
  backHref?: string;
  backLabel?: string;
  leftLink?: SiteLink;
  rightLinks?: SiteLink[];
}

const {
  title,
  description,
  heading = title,
  backHref = "/",
  backLabel = "home",
  leftLink = { href: "/", label: "home" },
  rightLinks = DEFAULT_PAGE_LINKS,
} = Astro.props as Props;
---

<BaseLayout title={`${title} · ${SITE_TITLE}`} description={description}>
  <main class="wrap" style="padding-top:22px;padding-bottom:64px;">
    <PageTopbar leftLink={leftLink} rightLinks={rightLinks} />

    <section class="section" style="padding-top:24px;">
      <div class="section-head">
        <h2 class="h2">{heading}</h2>
        <a class="more" href={backHref}>{backLabel}</a>
      </div>

      <slot />
    </section>
  </main>
</BaseLayout>
