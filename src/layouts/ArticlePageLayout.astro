---
import BaseLayout from "./BaseLayout.astro";
import PageTopbar from "../components/PageTopbar.astro";
import { DEFAULT_PAGE_LINKS, SITE_TITLE, buildBreadcrumbJsonLd, mergeKeywords, type SiteLink } from "../lib/site";

interface Props {
  title: string;
  description?: string;
  metaLabel?: string;
  metaValue?: string;
  backHref?: string;
  backLabel?: string;
  leftLink?: SiteLink;
  rightLinks?: SiteLink[];
  publishedTime?: string;
  modifiedTime?: string;
  tags?: string[];
  cover?: string;
  schemaType?: string;
}

const {
  title,
  description,
  metaLabel,
  metaValue,
  backHref,
  backLabel,
  leftLink = { href: "/", label: "home" },
  rightLinks = DEFAULT_PAGE_LINKS,
  publishedTime,
  modifiedTime,
  tags = [],
  cover,
  schemaType = "Article",
} = Astro.props as Props;

const pathname = Astro.url.pathname;
const pageKeywords = mergeKeywords([title, ...tags]);
const crumbs = [
  { name: "首页", path: "/" },
  ...(leftLink.href !== "/" ? [{ name: leftLink.label, path: leftLink.href }] : []),
  { name: title, path: pathname },
];
const articleJsonLd = {
  "@context": "https://schema.org",
  "@type": schemaType,
  headline: title,
  description,
  url: new URL(pathname, Astro.site).toString(),
  inLanguage: "zh-CN",
  datePublished: publishedTime,
  dateModified: modifiedTime ?? publishedTime,
  image: cover ? [new URL(cover, Astro.site).toString()] : undefined,
  keywords: pageKeywords.join(", "),
  mainEntityOfPage: new URL(pathname, Astro.site).toString(),
};
const jsonLd = [articleJsonLd, buildBreadcrumbJsonLd(crumbs)];
---

<BaseLayout
  title={`${title} · ${SITE_TITLE}`}
  description={description}
  keywords={pageKeywords}
  image={cover}
  ogType="article"
  publishedTime={publishedTime}
  modifiedTime={modifiedTime}
  jsonLd={jsonLd}
>
  <main class="wrap article-page">
    <PageTopbar leftLink={leftLink} rightLinks={rightLinks} />

    <article class="article">
      <header class="article-head">
        <h1 class="article-title">{title}</h1>
        {metaLabel ? (
          <div class="article-meta">
            <span class="article-date">{metaLabel}：{metaValue ?? "—"}</span>
          </div>
        ) : null}
        {description ? <p class="article-desc">{description}</p> : null}
      </header>

      <div class="prose">
        <slot />
      </div>

      {backHref && backLabel ? (
        <footer class="article-foot">
          <a class="pill-ink" href={backHref}>{backLabel}</a>
        </footer>
      ) : null}
    </article>
  </main>
</BaseLayout>
